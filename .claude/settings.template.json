{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/scripts/stop_hook.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/scripts/session_review.py session_start",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/scripts/session_review.py session_end",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|WebSearch|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/scripts/session_review.py post_tool_use",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/scripts/pre_tool_use_hook.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/scripts/user_prompt_hook.py",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/scripts/pre_compact_hook.py pre",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${HOME}/.claude/scripts/pre_compact_hook.py post",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(git *)",
      "Bash(curl *)",
      "Bash(python3 *)",
      "Bash(pip3 install *)",
      "Bash(sqlite3 ${HOME}/.claude/memory/harness.db *)"
    ],
    "defaultMode": "default"
  }
}
